SITE_URL=http://127.0.0.1:3000
CMS_BASE_URL=http://127.0.0.1:1337
CMS_FRONTEND_TOKEN=
CMS_BACKEND_TOKEN=
NODE_ENV=development

# same values as AWS_CDN_URL on backend/.env.example
CDN_IMAGES_URL=

# Supabase (Bright Brains)
# Public vars — exposed to browser (required for Supabase Auth client-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only vars — never exposed to browser
SUPABASE_URL=                    # same value as NEXT_PUBLIC_SUPABASE_URL
SUPABASE_ANON_KEY=               # same value as NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=       # admin key — only for server-side invite + code generation

# Anthropic (AI Report Generation)
ANTHROPIC_API_KEY=

# OpenRouter (fallback when Anthropic credits are exhausted)
OPENROUTER_API_KEY=

# n8n report webhook (still used elsewhere if configured)
N8N_REPORT_WEBHOOK_URL=

# Slack error notifications (used by frontend/shared/utils/notifications/notifyError.ts)
# Posts directly to Slack via the HowTheF Assistant bot's `chat:write` scope —
# no incoming webhook needed. Bot must be invited to the channel once
# (`/invite @HowTheF AI` in #howthef-errors).
#   1. Slack app → OAuth & Permissions → "Bot User OAuth Token" (xoxb-...)
SLACK_BOT_TOKEN=
#   2. Channel name (no #) or channel ID. Defaults to "howthef-errors".
SLACK_ERROR_CHANNEL=howthef-errors
# Optional fallback if SLACK_BOT_TOKEN is not set: a Slack Incoming Webhook URL.
SLACK_WEBHOOK_URL=

NEXT_PUBLIC_AVALIACAO_DEV_MODE=true